{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typeorm": "typeorm",
    "migration:create": "typeorm migration:create src/migrations/CreateResultsTable",
    "migration:generate": "typeorm migration:generate -d src/config/data-source.js src/migrations/CreateResultsTable -o",
    "migration:run": "typeorm migration:run -d src/config/data-source.js",
    "migration:revert": "typeorm migration:revert -d src/config/data-source.js",
    "migration:show": "typeorm migration:show -d src/config/data-source.js",
    "seed": "node src/seeds/seed.js"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}